# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001
# In production: https://api.yourdomain.com

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pr_review_agent

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URL: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub Webhook Secret — generate the same way as JWT_SECRET
GITHUB_WEBHOOK_SECRET=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-
